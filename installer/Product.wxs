<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
      Id="*"
      Name="AddyScript"
      Language="1033"
      Version="$(var.Version)"
      Manufacturer="Addy"
      UpgradeCode="D5DEFE7B-E1F2-4519-B72F-A73CA312BB14">

    <Package
        InstallerVersion="500"
        Compressed="yes"
        InstallScope="perMachine"/>

    <MajorUpgrade
        DowngradeErrorMessage="A newer version of AddyScript is already installed."/>

    <MediaTemplate EmbedCab="yes"/>

    <!-- ========================================================= -->
    <!-- INSTALLATION STRUCTURE -->
    <!-- ========================================================= -->

    <Directory Id="TARGETDIR" Name="SourceDir">
      <!-- Program Files -->
      <Directory Id="ProgramFilesFolder">
        <Directory Id="INSTALLFOLDER" Name="AddyScript"/>
      </Directory>

      <!-- Start Menu -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="AddyScript"/>
      </Directory>

      <!-- Desktop -->
      <Directory Id="DesktopFolder"/>
    </Directory>

    <!-- ========================================================= -->
    <!-- SHORTCUT COMPONENT -->
    <!-- ========================================================= -->

    <DirectoryRef Id="ApplicationProgramsFolder">
      <Component Id="StartMenuShortcut" Guid="*">
        <Shortcut
            Id="AsguiStartMenuShortcut"
            Name="AddyScript GUI"
            Description="AddyScript .NET Scripting Language"
            Target="[INSTALLFOLDER]asgui.exe"
            WorkingDirectory="INSTALLFOLDER"/>

        <Shortcut
            Id="AsisStartMenuShortcut"
            Name="AddyScript Interactive Shell"
            Description="AddyScript .NET Scripting Language"
            Target="[INSTALLFOLDER]asis.exe"
            WorkingDirectory="INSTALLFOLDER"/>

        <RemoveFolder
            Id="ApplicationProgramsFolder"
            On="uninstall"/>

        <RegistryValue
            Root="HKCU"
            Key="Software\AddyScript"
            Name="installed"
            Type="integer"
            Value="1"
            KeyPath="yes"/>
      </Component>
    </DirectoryRef>

    <!-- ========================================================= -->
    <!-- DESKTOP SHORTCUT -->
    <!-- ========================================================= -->

    <DirectoryRef Id="DesktopFolder">
      <Component Id="DesktopShortcut" Guid="*">
        <Shortcut
            Id="DesktopShortcut"
            Name="AddyScript"
            Description=".NET Scripting Language"
            Target="[INSTALLFOLDER]asgui.exe"
            WorkingDirectory="INSTALLFOLDER"/>

        <RegistryValue
            Root="HKCU"
            Key="Software\AddyScript"
            Name="desktopShortcut"
            Type="integer"
            Value="1"
            KeyPath="yes"/>
      </Component>
    </DirectoryRef>

    <!-- ========================================================= -->
    <!-- FEATURES -->
    <!-- ========================================================= -->

    <Feature
        Id="MainFeature"
        Title="AddyScript"
        Level="1">

      <!-- All published files from Heat -->
      <ComponentGroupRef Id="PublishedFiles"/>

      <!-- Shortcuts -->
      <ComponentRef Id="StartMenuShortcut"/>
      <ComponentRef Id="DesktopShortcut"/>
    </Feature>
  </Product>
</Wix>